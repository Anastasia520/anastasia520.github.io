---
const CONTACT_EMAIL = "stacypetrunina@gmail.com";
---

<section id="contact" class="content-section last-section">
	<div class="grid-container">
		<div class="section-header">
			<span>[04] Init_Contact</span>
		</div>

		<div class="contact-grid">
			<div class="contact-info">
				<h2 class="contact-title">Let's Connect.</h2>
				<p>
					I'm currently looking for new opportunities, my inbox is
					always open. Whether you have a question or just want to say
					hi, I'll try my best to get back to you!
				</p>
			</div>

			<a href={`mailto:${CONTACT_EMAIL}`} class="btn-primary"
				>Send me an email</a
			>
		</div>
	</div>
</section>

<style>
	.last-section {
		border-bottom: none;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.5fr;
		gap: 4rem;
		align-items: center;
	}

	.contact-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}

	.contact-info p {
		color: var(--text-muted);
		margin-bottom: 2rem;
		font-size: 1.1rem;
	}

	.btn-primary {
		display: inline-block;
		background: var(--text-main);
		color: var(--bg-base);
		padding: 1rem 2rem;
		border: 1px solid var(--text-main);
		font-family: var(--font-mono);
		font-weight: bold;
		text-transform: uppercase;
		font-size: 0.9rem;
		cursor: pointer;
		text-decoration: none;
		transition: all var(--transition-fast);
		align-self: center;
		justify-self: start;
	}

	.btn-primary:hover {
		background: var(--bg-base);
		color: var(--accent-cyan);
		border-color: var(--accent-cyan);
	}

	@media (max-width: 900px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.btn-primary {
			justify-self: stretch;
			text-align: center;
		}
	}
</style>
