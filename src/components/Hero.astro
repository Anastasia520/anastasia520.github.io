---

---

<section class="hero grid-container" id="about">
	<div class="hero-label fade-up delay-1">Hi there, I'm</div>
	<h1 class="hero-title fade-up delay-2">Anastasiia<br />Petrunina.</h1>
	<div
		class="hero-subtitle typing fade-up delay-3"
		id="typewriter-subtitle"
		data-text="Software Engineer"
	>
	</div>
	<p class="hero-desc fade-up delay-4">
		Frontend-leaning Full Stack Engineer. I focus on delivering
		high-performance user interfaces and bring hands-on experience
		developing the APIs and database structures that support them. I value
		practical software design, clean data flow, and end-to-end system
		reliability.
	</p>
</section>

<style>
	.hero {
		padding-top: 15vh;
		padding-bottom: 10vh;
	}

	@media (max-width: 768px) {
		.hero {
			padding-top: 6vh;
			padding-bottom: 6vh;
		}
	}

	.hero-label {
		font-family: var(--font-mono);
		color: var(--text-muted);
		font-size: 0.85rem;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
		display: inline-block;
	}

	.hero-title {
		font-size: clamp(3rem, 7vw, 6.5rem);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.04em;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.hero-subtitle {
		font-family: var(--font-mono);
		color: var(--accent-cyan);
		font-size: clamp(1rem, 2vw, 1.5rem);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 3rem;
		font-weight: bold;
		min-height: 1.5em; /* Prevents layout shift during typing */
		position: relative;
	}

	.hero-subtitle.typing::after {
		content: "";
		display: inline-block;
		width: 8px;
		height: 1em;
		background-color: var(--accent-cyan);
		vertical-align: text-bottom;
		margin-left: 5px;
	}

	.hero-desc {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: var(--text-muted);
		max-width: 650px;
		font-family: var(--font-mono);
		line-height: 1.6;
	}
</style>

<script>
	function setupTypewriter() {
		const el = document.getElementById("typewriter-subtitle");
		if (!el || el.dataset.typed === "true") return;

		const fullText = el.dataset.text ?? "";
		el.dataset.typed = "true";

		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;
		if (prefersReducedMotion) {
			el.textContent = fullText;
			el.classList.remove("typing");
			return;
		}

		let charIndex = 0;

		// Natural variable cadence: quick on most letters, brief pause after spaces.
		function nextDelay(char: string) {
			const base = 25 + Math.random() * 35;
			return char === " " ? base + 60 : base;
		}

		function typeWriter() {
			if (!el) return;
			if (charIndex < fullText.length) {
				const char = fullText.charAt(charIndex);
				el.textContent += char;
				charIndex++;
				setTimeout(typeWriter, nextDelay(char));
			} else {
				el.classList.remove("typing");
			}
		}

		setTimeout(typeWriter, 400);
	}

	setupTypewriter();
	document.addEventListener("astro:after-swap", setupTypewriter);
</script>
