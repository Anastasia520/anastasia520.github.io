---
const coreStack = [
	"React / Angular",
	"TypeScript",
	"Node.js / Express",
	"Python / Django",
	"Docker / CI/CD",
];
const languages = [
	{ name: "English", level: "Advanced" },
	{ name: "German", level: "Pre-intermediate" },
	{ name: "Russian", level: "Native" },
];
---

<section class="metrics-grid grid-container">
	<div class="metric-block">
		<div class="metric-title">Core_Stack</div>
		<ul class="tech-list">
			{coreStack.map((tech) => <li>{tech}</li>)}
		</ul>
	</div>
	<div class="metric-block">
		<div class="metric-title">Languages</div>
		<ul class="tech-list lang-list">
			{
				languages.map((lang) => (
					<li>
						<strong>{lang.name}</strong> // {lang.level}
					</li>
				))
			}
		</ul>
	</div>
	<div class="metric-block">
		<div class="metric-title">Education</div>
		<div class="metric-data">
			HSE University<br />
			<span class="metric-sub">Bachelor, Software Engineering</span><br />
		</div>
	</div>
</section>

<style>
	.metrics-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		border-top: 1px solid var(--border-hard);
		border-bottom: 1px solid var(--border-hard);
		padding: 0;
	}

	.metric-block {
		padding: 3rem 2rem;
		border-right: 1px solid var(--border-hard);
		transition: background var(--transition-fast);
	}

	.metric-block:hover {
		background: var(--bg-surface);
	}

	.metric-block:last-child {
		border-right: none;
	}

	.metric-title {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-muted);
		text-transform: uppercase;
		margin-bottom: 1rem;
	}

	.metric-data {
		font-size: 1.1rem;
		font-weight: 500;
		line-height: 1.5;
		color: var(--text-main);
	}

	.metric-sub {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.tech-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tech-list li {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		background: var(--bg-surface);
		border: 1px solid var(--border-dim);
		padding: 0.25rem 0.75rem;
		color: var(--text-main);
	}

	.lang-list {
		flex-direction: column;
		gap: 0.75rem;
	}

	.lang-list li {
		background: transparent;
		border: none;
		padding: 0;
		font-size: 0.95rem;
	}
</style>
