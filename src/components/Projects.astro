---
interface Project {
	name: string;
	image?: string;
	description: string;
	tags: string[];
	href?: string;
	github?: string;
}

const projects: Project[] = [
	{
		name: "DeskAlerts Admin Panel",
		image: "/images/deskalerts.png",
		description:
			"An admin panel for managing corporate and emergency messages and notifications across companies, hospitals, and schools, with real-time messaging, user group management, and priority notifications.",
		tags: [
			"React",
			"Redux",
			"HTML/CSS",
			"MUI",
			"SASS",
			"Webpack",
			"BundleAnalyzer",
		],
		href: "https://www.alert-software.com/",
	},
	{
		name: "CRM for a Real Estate Agency",
		image: "/images/crm.png",
		description:
			"A CRM system automating realtor and sales manager workflows, streamlining client management, property listings, and sales tracking with automated follow-ups and integrated communication tools.",
		tags: [
			"React",
			"TypeScript",
			"Django",
			"Python",
			"Redux",
			"Storybook",
			"Cypress",
			"Loki",
			"CI",
			"Jest",
			"SASS",
			"MUI",
			"React Testing Library",
			"Three.js",
		],
	},
	{
		name: "Company Involvement Tracker",
		image: "/images/mobileapp.png",
		description:
			"A mobile app for assessing and boosting employee engagement, letting employees join extracurricular activities and earn points redeemable for rewards.",
		tags: [
			"React Native",
			"Expo",
			"JavaScript",
			"CSS-in-JS",
			"Auth0",
			"GraphQL",
			"Firebase",
		],
	},
	{
		name: "Energy Data Platform",
		description:
			"Architected a highly scalable backend utilizing Docker, optimized for complex querying across a 1.5M+ record database.",
		tags: ["React", "Node.js", "Express", "TypeScript"],
		github: "https://github.com/Anastasia520/Energy-Data-Platform",
	},
	{
		name: "Remote Control App",
		description:
			"Developed a mobile application for remotely controlling AI-enabled consumer electronic devices with Android OS integration.",
		tags: ["Python", "Django", "React"],
	},
	{
		name: "3D Learning Engine",
		description:
			"Engineered a 3D game utilizing Rapier Physics for realistic body collisions and interactions to facilitate language learning.",
		tags: ["React Three Fiber", "Zustand", "Vite"],
		github: "https://github.com/Anastasia520/3D-game-for-learning-the-Japanese-alphabet",
	},
	{
		name: "Coffee App",
		description:
			"A React Native app for a seamless coffee ordering experience, with a dynamic product carousel and Yookassa payment integration for secure in-app transactions.",
		tags: ["React Native", "TypeScript", "Expo", "Redux Toolkit", "Vite"],
	},
];
---

<section id="projects" class="content-section">
	<div class="grid-container">
		<div class="section-header">
			<span>[03] Projects</span>
			<span>Found: {projects.length} Records</span>
		</div>

		<div class="project-grid">
			{
				projects.map((project) => (
					<div class="project-card">
						{project.image ? (
							<div class="project-img">
								<img
									src={project.image}
									alt={`${project.name} preview`}
									loading="lazy"
								/>
							</div>
						) : null}
						<div class="project-info">
							<h3>{project.name}</h3>
							<p>{project.description}</p>
							<div class="card-tech-tags">
								{project.tags.map((tag) => (
									<span>{tag}</span>
								))}
							</div>
							{(project.github || project.href) && (
								<div class="card-links">
									{project.github && (
										<a
											href={project.github}
											target="_blank"
											rel="noopener noreferrer"
											aria-label={`View ${project.name} source on GitHub`}
											class="card-link-icon"
										>
											<svg
												viewBox="0 0 24 24"
												aria-hidden="true"
												class="icon-fill"
											>
												<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
											</svg>
										</a>
									)}
									{project.href && (
										<a
											href={project.href}
											target="_blank"
											rel="noopener noreferrer"
											aria-label={`View ${project.name} live site`}
											class="card-link-icon"
										>
											<svg
												viewBox="0 0 24 24"
												aria-hidden="true"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
												<polyline points="15 3 21 3 21 9" />
												<line
													x1="10"
													y1="14"
													x2="21"
													y2="3"
												/>
											</svg>
										</a>
									)}
								</div>
							)}
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2rem;
	}

	.project-card {
		background: var(--bg-surface);
		border: 1px solid var(--border-hard);
		transition: border-color var(--transition-fast);
		display: flex;
		flex-direction: column;
	}

	.project-card:hover {
		border-color: var(--accent-cyan);
	}

	.project-img {
		width: 100%;
		height: 220px;
		background: var(--bg-base);
		border-bottom: 1px solid var(--border-hard);
		position: relative;
		overflow: hidden;
	}

	.project-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@media (max-width: 768px) {
		.project-img img {
			object-fit: contain;
		}
	}

	.project-img::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: var(--accent-cyan);
		opacity: 0;
		transition: opacity var(--transition-fast);
		mix-blend-mode: overlay;
	}

	.project-card:hover .project-img::after {
		opacity: 0.1;
	}

	.project-info {
		padding: 2rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.project-info h3 {
		font-size: 1.5rem;
		margin-bottom: 0.75rem;
	}

	.project-info p {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	.card-tech-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.card-tech-tags span {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 0.2rem 0.5rem;
		border: 1px solid var(--border-dim);
		color: var(--text-muted);
		text-transform: uppercase;
	}

	.card-links {
		display: flex;
		gap: 1rem;
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border-dim);
	}

	.card-link-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		color: var(--text-muted);
		border: 1px solid var(--border-dim);
		transition:
			color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.card-link-icon:hover,
	.card-link-icon:focus-visible {
		color: var(--accent-cyan);
		border-color: var(--accent-cyan);
	}

	.card-link-icon svg {
		width: 18px;
		height: 18px;
	}

	.card-link-icon svg.icon-fill {
		fill: currentColor;
	}
</style>
